---
import type { ImageRef } from '../types/griin';
import { imgSrc, imgAlt } from '../lib/content';

interface Props {
  galeria: ImageRef[];
  titulo: string;
}

const { galeria, titulo } = Astro.props;
const fotos = galeria.filter((g) => imgSrc(g));
const total = fotos.length;
const main = fotos[0];
---

{total > 0 && (
  <section class="gallery" aria-label="Galería de fotos" data-gallery>
    <div class="gallery__stage">
      <img
        class="gallery__main-img"
        data-gallery-main
        src={imgSrc(main)}
        alt={imgAlt(main, `${titulo} — foto 1`)}
        fetchpriority="high"
        width="1280"
        height="854"
      />

      <button class="gallery__zoom" type="button" data-gallery-open aria-label="Ampliar galería">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
        <span>Ampliar</span>
      </button>

      <span class="gallery__counter" aria-hidden="true">
        <span data-gallery-current>1</span> / {total}
      </span>

      {total > 1 && (
        <>
          <button class="gallery__nav gallery__nav--prev" type="button" data-gallery-prev aria-label="Foto anterior">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
          </button>
          <button class="gallery__nav gallery__nav--next" type="button" data-gallery-next aria-label="Foto siguiente">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </>
      )}
    </div>

    {total > 1 && (
      <ul class="gallery__thumbs" role="list">
        {fotos.map((g, i) => (
          <li class="gallery__thumb-item">
            <button
              class:list={['gallery__thumb', i === 0 && 'is-active']}
              type="button"
              data-gallery-thumb={i}
              aria-label={`Ver foto ${i + 1} de ${total}`}
            >
              <img
                src={imgSrc(g)}
                alt={imgAlt(g, `${titulo} — foto ${i + 1}`)}
                loading="lazy"
                width="200"
                height="150"
              />
            </button>
          </li>
        ))}
      </ul>
    )}

    {/* Lightbox overlay (oculto hasta abrir). */}
    <div class="lightbox" data-lightbox hidden role="dialog" aria-modal="true" aria-label="Galería ampliada">
      <div class="lightbox__backdrop" data-lightbox-close></div>
      <div class="lightbox__shell">
        <header class="lightbox__bar">
          <span class="lightbox__counter">
            <span data-lightbox-current>1</span> / {total}
          </span>
          <button class="lightbox__close" type="button" data-lightbox-close aria-label="Cerrar galería">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
          </button>
        </header>

        <div class="lightbox__viewport">
          {total > 1 && (
            <button class="lightbox__nav lightbox__nav--prev" type="button" data-lightbox-prev aria-label="Foto anterior">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
            </button>
          )}
          <figure class="lightbox__figure">
            <img class="lightbox__img" data-lightbox-img src={imgSrc(main)} alt={imgAlt(main, titulo)} />
          </figure>
          {total > 1 && (
            <button class="lightbox__nav lightbox__nav--next" type="button" data-lightbox-next aria-label="Foto siguiente">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
            </button>
          )}
        </div>
      </div>

      <script type="application/json" data-gallery-data set:html={JSON.stringify(
        fotos.map((g, i) => ({ src: imgSrc(g), alt: imgAlt(g, `${titulo} — foto ${i + 1}`) }))
      )} />
    </div>
  </section>
)}

<script>
  document.querySelectorAll<HTMLElement>('[data-gallery]').forEach((root) => {
    const dataEl = root.querySelector<HTMLScriptElement>('[data-gallery-data]');
    let fotos: { src: string; alt: string }[] = [];
    try { fotos = JSON.parse(dataEl?.textContent || '[]'); } catch { fotos = []; }
    if (!fotos.length) return;

    const mainImg = root.querySelector<HTMLImageElement>('[data-gallery-main]');
    const stageCounter = root.querySelector<HTMLElement>('[data-gallery-current]');
    const thumbs = Array.from(root.querySelectorAll<HTMLElement>('[data-gallery-thumb]'));
    const lightbox = root.querySelector<HTMLElement>('[data-lightbox]');
    const lbImg = root.querySelector<HTMLImageElement>('[data-lightbox-img]');
    const lbCounter = root.querySelector<HTMLElement>('[data-lightbox-current]');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let index = 0;
    let lastFocused: HTMLElement | null = null;

    // ── Stage (imagen principal, cambia con thumbnails / flechas) ──
    function setStage(i: number) {
      index = (i + fotos.length) % fotos.length;
      const f = fotos[index];
      if (mainImg && f) { mainImg.src = f.src; mainImg.alt = f.alt; }
      if (stageCounter) stageCounter.textContent = String(index + 1);
      thumbs.forEach((t, n) => t.classList.toggle('is-active', n === index));
      const active = thumbs[index];
      active?.scrollIntoView({ block: 'nearest', inline: 'center', behavior: reduce ? 'auto' : 'smooth' });
      if (lbImg && f && lightbox && !lightbox.hidden) { lbImg.src = f.src; lbImg.alt = f.alt; }
      if (lbCounter) lbCounter.textContent = String(index + 1);
    }

    thumbs.forEach((t) => t.addEventListener('click', () => setStage(Number(t.dataset.galleryThumb) || 0)));
    root.querySelector<HTMLElement>('[data-gallery-prev]')?.addEventListener('click', () => setStage(index - 1));
    root.querySelector<HTMLElement>('[data-gallery-next]')?.addEventListener('click', () => setStage(index + 1));

    // ── Lightbox (fullscreen) ──
    function focusables(): HTMLElement[] {
      return Array.from(lightbox!.querySelectorAll<HTMLElement>('button:not([disabled])')).filter((el) => el.offsetParent !== null);
    }
    function open() {
      if (!lightbox || !lbImg) return;
      setStage(index);
      lastFocused = document.activeElement as HTMLElement;
      lightbox.hidden = false;
      document.body.style.overflow = 'hidden';
      if (!reduce) requestAnimationFrame(() => lightbox.classList.add('lightbox--open'));
      else lightbox.classList.add('lightbox--open');
      lightbox.querySelector<HTMLElement>('.lightbox__close')?.focus();
      document.addEventListener('keydown', onKey);
    }
    function close() {
      if (!lightbox) return;
      lightbox.classList.remove('lightbox--open');
      document.removeEventListener('keydown', onKey);
      document.body.style.overflow = '';
      if (reduce) lightbox.hidden = true; else window.setTimeout(() => { lightbox.hidden = true; }, 200);
      lastFocused?.focus();
    }
    function onKey(e: KeyboardEvent) {
      if (e.key === 'Escape') { e.preventDefault(); close(); }
      else if (e.key === 'ArrowRight') { e.preventDefault(); setStage(index + 1); }
      else if (e.key === 'ArrowLeft') { e.preventDefault(); setStage(index - 1); }
      else if (e.key === 'Tab') {
        const els = focusables();
        if (!els.length) return;
        const first = els[0], last = els[els.length - 1];
        if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
        else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    }

    mainImg?.addEventListener('click', open);
    root.querySelector<HTMLElement>('[data-gallery-open]')?.addEventListener('click', open);
    lightbox?.querySelectorAll<HTMLElement>('[data-lightbox-close]').forEach((el) => el.addEventListener('click', close));
    lightbox?.querySelector<HTMLElement>('[data-lightbox-next]')?.addEventListener('click', () => setStage(index + 1));
    lightbox?.querySelector<HTMLElement>('[data-lightbox-prev]')?.addEventListener('click', () => setStage(index - 1));
  });
</script>

<style>
  .gallery { display: flex; flex-direction: column; gap: 0.85rem; }

  .gallery__stage {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: clip;
    aspect-ratio: 3 / 2;
    background-color: var(--color-surface-sunken);
  }
  .gallery__main-img {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    cursor: zoom-in;
    display: block;
  }

  .gallery__zoom {
    position: absolute;
    inset-block-start: 0.9rem;
    inset-inline-end: 0.9rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.45rem 0.8rem;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-on-brand);
    background-color: var(--color-overlay);
    border: 0;
    border-radius: var(--radius-pill);
    backdrop-filter: blur(4px);
    cursor: pointer;
    transition: background-color var(--duration-base) var(--ease-out);
  }
  .gallery__zoom:hover { background-color: var(--color-brand); }
  .gallery__zoom:focus-visible { outline: 2px solid var(--color-on-brand); outline-offset: 2px; }

  .gallery__counter {
    position: absolute;
    inset-block-start: 0.9rem;
    inset-inline-start: 0.9rem;
    padding: 0.4rem 0.75rem;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-on-brand);
    background-color: var(--color-overlay);
    border-radius: var(--radius-pill);
    backdrop-filter: blur(4px);
    pointer-events: none;
  }

  .gallery__nav {
    position: absolute;
    inset-block-start: 50%;
    transform: translateY(-50%);
    display: inline-flex;
    padding: 0.6rem;
    color: var(--color-ink);
    background-color: color-mix(in srgb, var(--color-surface) 85%, transparent);
    border: 0;
    border-radius: var(--radius-pill);
    box-shadow: var(--shadow-card);
    cursor: pointer;
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out), background-color var(--duration-base) var(--ease-out);
  }
  .gallery__stage:hover .gallery__nav,
  .gallery__nav:focus-visible { opacity: 1; }
  .gallery__nav:hover { background-color: var(--color-surface); }
  .gallery__nav--prev { inset-inline-start: 0.75rem; }
  .gallery__nav--next { inset-inline-end: 0.75rem; }
  @media (hover: none) { .gallery__nav { opacity: 1; } }

  /* Tira de miniaturas (scroll horizontal, activa resaltada) */
  .gallery__thumbs {
    display: flex;
    gap: 0.6rem;
    list-style: none;
    margin: 0;
    padding: 0.2rem;
    overflow-x: auto;
    scrollbar-width: thin;
    scroll-snap-type: x proximity;
  }
  .gallery__thumb-item { flex: 0 0 auto; scroll-snap-align: center; }
  .gallery__thumb {
    display: block;
    inline-size: clamp(78px, 14vw, 104px);
    aspect-ratio: 4 / 3;
    padding: 0;
    border: 2px solid transparent;
    border-radius: var(--radius-md);
    overflow: clip;
    cursor: pointer;
    background-color: var(--color-surface-sunken);
    opacity: 0.7;
    transition: border-color var(--duration-base) var(--ease-out), opacity var(--duration-base) var(--ease-out);
  }
  .gallery__thumb img { inline-size: 100%; block-size: 100%; object-fit: cover; }
  .gallery__thumb:hover { opacity: 1; }
  .gallery__thumb:focus-visible { outline: 2px solid var(--color-focus-ring); outline-offset: 2px; }
  .gallery__thumb.is-active { border-color: var(--color-brand); opacity: 1; }

  /* ── Lightbox ──────────────────────────────────────────── */
  .lightbox { position: fixed; inset: 0; z-index: 1000; display: flex; align-items: center; justify-content: center; }
  .lightbox__backdrop {
    position: absolute; inset: 0;
    background-color: rgb(8 14 10 / 0.92);
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out);
  }
  .lightbox--open .lightbox__backdrop { opacity: 1; }
  .lightbox__shell {
    position: relative; z-index: 1;
    display: flex; flex-direction: column;
    inline-size: min(100%, 72rem); block-size: 100%;
    padding: clamp(0.75rem, 2vw, 1.5rem);
    opacity: 0; transform: scale(0.98);
    transition: opacity var(--duration-base) var(--ease-out), transform var(--duration-base) var(--ease-out);
  }
  .lightbox--open .lightbox__shell { opacity: 1; transform: scale(1); }
  .lightbox__bar { display: flex; align-items: center; justify-content: space-between; gap: 1rem; color: var(--color-on-brand); padding-block-end: 0.75rem; }
  .lightbox__counter { font-family: var(--font-heading); font-weight: 600; font-size: 0.95rem; }
  .lightbox__close {
    display: inline-flex; padding: 0.5rem;
    color: var(--color-on-brand);
    background-color: color-mix(in srgb, var(--color-on-brand) 12%, transparent);
    border: 0; border-radius: var(--radius-pill); cursor: pointer;
    transition: background-color var(--duration-base) var(--ease-out);
  }
  .lightbox__close:hover { background-color: color-mix(in srgb, var(--color-on-brand) 24%, transparent); }
  .lightbox__close:focus-visible { outline: 2px solid var(--color-on-brand); outline-offset: 2px; }
  .lightbox__viewport { position: relative; display: flex; align-items: center; justify-content: center; gap: 0.5rem; flex: 1; min-block-size: 0; }
  .lightbox__figure { margin: 0; display: flex; align-items: center; justify-content: center; max-block-size: 100%; }
  .lightbox__img { max-inline-size: 100%; max-block-size: 80vh; object-fit: contain; border-radius: var(--radius-md); }
  .lightbox__nav {
    display: inline-flex; flex: 0 0 auto; padding: 0.75rem;
    color: var(--color-on-brand);
    background-color: color-mix(in srgb, var(--color-on-brand) 12%, transparent);
    border: 0; border-radius: var(--radius-pill); cursor: pointer;
    transition: background-color var(--duration-base) var(--ease-out);
  }
  .lightbox__nav:hover { background-color: var(--color-brand); }
  .lightbox__nav:focus-visible { outline: 2px solid var(--color-on-brand); outline-offset: 2px; }
  @media (max-width: 40rem) {
    .lightbox__nav { position: absolute; inset-block-start: 50%; transform: translateY(-50%); z-index: 2; }
    .lightbox__nav--prev { inset-inline-start: 0; }
    .lightbox__nav--next { inset-inline-end: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    .lightbox__backdrop, .lightbox__shell { transition: none; }
  }
</style>
