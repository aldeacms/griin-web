---
import type { ImageRef } from '../types/griin';
import { imgSrc, imgAlt } from '../lib/content';

interface Props {
  galeria: ImageRef[];
  titulo: string;
}

const { galeria, titulo } = Astro.props;
const fotos = galeria.filter((g) => imgSrc(g));
const total = fotos.length;
const main = fotos[0];
---

{total > 0 && (
  <section class="gallery" aria-label="Galería de fotos" data-gallery>
    <div class="gallery__stage">
      <button
        class="gallery__main"
        type="button"
        data-gallery-open="0"
        aria-label="Ampliar foto 1 de {total}"
      >
        <img
          class="gallery__main-img"
          src={imgSrc(main)}
          alt={imgAlt(main, `${titulo} — foto 1`)}
          fetchpriority="high"
          width="1280"
          height="854"
        />
      </button>

      <span class="gallery__counter" aria-hidden="true">
        <span data-gallery-current>1</span> / {total}
      </span>

      <span class="gallery__expand" aria-hidden="true">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7"/></svg>
        Ampliar
      </span>
    </div>

    {total > 1 && (
      <ul class="gallery__thumbs" role="list">
        {fotos.map((g, i) => (
          <li class="gallery__thumb-item">
            <button
              class="gallery__thumb"
              type="button"
              data-gallery-open={i}
              aria-label={`Ver foto ${i + 1} de ${total}`}
            >
              <img
                src={imgSrc(g)}
                alt={imgAlt(g, `${titulo} — foto ${i + 1}`)}
                loading="lazy"
                width="320"
                height="240"
              />
            </button>
          </li>
        ))}
      </ul>
    )}

    {/* Lightbox overlay (oculto hasta abrir). */}
    <div class="lightbox" data-lightbox hidden role="dialog" aria-modal="true" aria-label="Galería ampliada">
      <div class="lightbox__backdrop" data-lightbox-close></div>
      <div class="lightbox__shell">
        <header class="lightbox__bar">
          <span class="lightbox__counter">
            <span data-lightbox-current>1</span> / {total}
          </span>
          <button class="lightbox__close" type="button" data-lightbox-close aria-label="Cerrar galería">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 6 6 18M6 6l12 12"/></svg>
          </button>
        </header>

        <div class="lightbox__viewport">
          {total > 1 && (
            <button class="lightbox__nav lightbox__nav--prev" type="button" data-lightbox-prev aria-label="Foto anterior">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
            </button>
          )}
          <figure class="lightbox__figure">
            <img class="lightbox__img" data-lightbox-img src={imgSrc(main)} alt={imgAlt(main, titulo)} />
          </figure>
          {total > 1 && (
            <button class="lightbox__nav lightbox__nav--next" type="button" data-lightbox-next aria-label="Foto siguiente">
              <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
            </button>
          )}
        </div>
      </div>

      {/* Datos de la galería para el script. */}
      <script type="application/json" data-gallery-data set:html={JSON.stringify(
        fotos.map((g, i) => ({ src: imgSrc(g), alt: imgAlt(g, `${titulo} — foto ${i + 1}`) }))
      )} />
    </div>
  </section>
)}

<script>
  document.querySelectorAll<HTMLElement>('[data-gallery]').forEach((root) => {
    const dataEl = root.querySelector<HTMLScriptElement>('[data-gallery-data]');
    let fotos: { src: string; alt: string }[] = [];
    try { fotos = JSON.parse(dataEl?.textContent || '[]'); } catch { fotos = []; }
    if (!fotos.length) return;

    const lightbox = root.querySelector<HTMLElement>('[data-lightbox]');
    const img = root.querySelector<HTMLImageElement>('[data-lightbox-img]');
    const counter = root.querySelector<HTMLElement>('[data-lightbox-current]');
    const mainImg = root.querySelector<HTMLImageElement>('.gallery__main-img');
    const stageCounter = root.querySelector<HTMLElement>('[data-gallery-current]');
    if (!lightbox || !img || !counter) return;

    let index = 0;
    let lastFocused: HTMLElement | null = null;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function render() {
      const f = fotos[index];
      if (img && f) { img.src = f.src; img.alt = f.alt; }
      if (counter) counter.textContent = String(index + 1);
    }

    function focusables(): HTMLElement[] {
      return Array.from(
        lightbox!.querySelectorAll<HTMLElement>('button:not([disabled])')
      ).filter((el) => el.offsetParent !== null);
    }

    function open(i: number) {
      index = Math.max(0, Math.min(i, fotos.length - 1));
      render();
      lastFocused = document.activeElement as HTMLElement;
      lightbox!.hidden = false;
      document.body.style.overflow = 'hidden';
      if (!reduce) requestAnimationFrame(() => lightbox!.classList.add('lightbox--open'));
      else lightbox!.classList.add('lightbox--open');
      const close = lightbox!.querySelector<HTMLElement>('.lightbox__close');
      close?.focus();
      document.addEventListener('keydown', onKey);
    }

    function close() {
      lightbox!.classList.remove('lightbox--open');
      document.removeEventListener('keydown', onKey);
      document.body.style.overflow = '';
      const finish = () => { lightbox!.hidden = true; };
      if (reduce) finish();
      else window.setTimeout(finish, 200);
      lastFocused?.focus();
    }

    function next() { index = (index + 1) % fotos.length; render(); }
    function prev() { index = (index - 1 + fotos.length) % fotos.length; render(); }

    function onKey(e: KeyboardEvent) {
      if (e.key === 'Escape') { e.preventDefault(); close(); }
      else if (e.key === 'ArrowRight') { e.preventDefault(); next(); }
      else if (e.key === 'ArrowLeft') { e.preventDefault(); prev(); }
      else if (e.key === 'Tab') {
        const els = focusables();
        if (!els.length) return;
        const first = els[0], last = els[els.length - 1];
        if (e.shiftKey && document.activeElement === first) { e.preventDefault(); last.focus(); }
        else if (!e.shiftKey && document.activeElement === last) { e.preventDefault(); first.focus(); }
      }
    }

    // Mantén el stage (imagen grande visible) en sync al navegar dentro del lightbox.
    function syncStage() {
      const f = fotos[index];
      if (mainImg && f) { mainImg.src = f.src; mainImg.alt = f.alt; }
      if (stageCounter) stageCounter.textContent = String(index + 1);
    }

    root.querySelectorAll<HTMLElement>('[data-gallery-open]').forEach((btn) => {
      btn.addEventListener('click', () => open(Number(btn.dataset.galleryOpen) || 0));
    });
    lightbox.querySelectorAll<HTMLElement>('[data-lightbox-close]').forEach((el) => el.addEventListener('click', close));
    lightbox.querySelector<HTMLElement>('[data-lightbox-next]')?.addEventListener('click', () => { next(); syncStage(); });
    lightbox.querySelector<HTMLElement>('[data-lightbox-prev]')?.addEventListener('click', () => { prev(); syncStage(); });
  });
</script>

<style>
  .gallery { display: flex; flex-direction: column; gap: 0.85rem; }

  .gallery__stage {
    position: relative;
    border-radius: var(--radius-lg);
    overflow: clip;
    aspect-ratio: 3 / 2;
    background-color: var(--color-surface-sunken);
  }
  .gallery__main {
    display: block;
    inline-size: 100%;
    block-size: 100%;
    padding: 0;
    border: 0;
    background: none;
    cursor: zoom-in;
  }
  .gallery__main-img { inline-size: 100%; block-size: 100%; object-fit: cover; }
  .gallery__main:focus-visible { outline: 3px solid var(--color-focus-ring); outline-offset: -3px; }

  .gallery__counter,
  .gallery__expand {
    position: absolute;
    inset-block-start: 0.9rem;
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.4rem 0.75rem;
    font-family: var(--font-heading);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-on-brand);
    background-color: var(--color-overlay);
    border-radius: var(--radius-pill);
    backdrop-filter: blur(4px);
    pointer-events: none;
  }
  .gallery__counter { inset-inline-start: 0.9rem; }
  .gallery__expand { inset-inline-end: 0.9rem; }

  .gallery__thumbs {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 0.7rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .gallery__thumb {
    display: block;
    inline-size: 100%;
    aspect-ratio: 4 / 3;
    padding: 0;
    border: 2px solid transparent;
    border-radius: var(--radius-md);
    overflow: clip;
    cursor: pointer;
    background-color: var(--color-surface-sunken);
    transition: border-color var(--duration-base) var(--ease-out), transform var(--duration-base) var(--ease-out);
  }
  .gallery__thumb img { inline-size: 100%; block-size: 100%; object-fit: cover; }
  .gallery__thumb:hover { transform: translateY(-2px); }
  .gallery__thumb:hover,
  .gallery__thumb:focus-visible { border-color: var(--color-brand); outline: none; }

  @media (max-width: 48rem) { .gallery__thumbs { grid-template-columns: repeat(4, 1fr); } }
  @media (max-width: 30rem) { .gallery__thumbs { grid-template-columns: repeat(3, 1fr); } }

  /* ── Lightbox ──────────────────────────────────────────── */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .lightbox__backdrop {
    position: absolute;
    inset: 0;
    background-color: rgb(8 14 10 / 0.92);
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out);
  }
  .lightbox--open .lightbox__backdrop { opacity: 1; }

  .lightbox__shell {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    inline-size: min(100%, 72rem);
    block-size: 100%;
    padding: clamp(0.75rem, 2vw, 1.5rem);
    opacity: 0;
    transform: scale(0.98);
    transition: opacity var(--duration-base) var(--ease-out), transform var(--duration-base) var(--ease-out);
  }
  .lightbox--open .lightbox__shell { opacity: 1; transform: scale(1); }

  .lightbox__bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: var(--color-on-brand);
    padding-block-end: 0.75rem;
  }
  .lightbox__counter { font-family: var(--font-heading); font-weight: 600; font-size: 0.95rem; }
  .lightbox__close {
    display: inline-flex;
    padding: 0.5rem;
    color: var(--color-on-brand);
    background-color: color-mix(in srgb, var(--color-on-brand) 12%, transparent);
    border: 0;
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: background-color var(--duration-base) var(--ease-out);
  }
  .lightbox__close:hover { background-color: color-mix(in srgb, var(--color-on-brand) 24%, transparent); }
  .lightbox__close:focus-visible { outline: 2px solid var(--color-on-brand); outline-offset: 2px; }

  .lightbox__viewport {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    flex: 1;
    min-block-size: 0;
  }
  .lightbox__figure { margin: 0; display: flex; align-items: center; justify-content: center; max-block-size: 100%; }
  .lightbox__img {
    max-inline-size: 100%;
    max-block-size: 80vh;
    object-fit: contain;
    border-radius: var(--radius-md);
  }
  .lightbox__nav {
    display: inline-flex;
    flex: 0 0 auto;
    padding: 0.75rem;
    color: var(--color-on-brand);
    background-color: color-mix(in srgb, var(--color-on-brand) 12%, transparent);
    border: 0;
    border-radius: var(--radius-pill);
    cursor: pointer;
    transition: background-color var(--duration-base) var(--ease-out);
  }
  .lightbox__nav:hover { background-color: var(--color-brand); }
  .lightbox__nav:focus-visible { outline: 2px solid var(--color-on-brand); outline-offset: 2px; }
  @media (max-width: 40rem) {
    .lightbox__nav { position: absolute; inset-block-start: 50%; transform: translateY(-50%); z-index: 2; }
    .lightbox__nav--prev { inset-inline-start: 0; }
    .lightbox__nav--next { inset-inline-end: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .lightbox__backdrop,
    .lightbox__shell { transition: none; }
  }
</style>
