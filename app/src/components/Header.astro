---
import { getConfig } from '../lib/content';

const config = await getConfig();
const { nav, whatsapp, marca } = config;
const waUrl = `https://wa.me/${whatsapp.numero}?text=${encodeURIComponent(whatsapp.mensaje_default)}`;
const current = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (url: string) => {
  const u = url.replace(/\/$/, '') || '/';
  return u === '/' ? current === '/' : current === u || current.startsWith(u + '/');
};
---

<header class="site-header">
  <div class="container site-header__inner">
    <a class="site-header__brand" href="/" aria-label={`${marca.nombre} — Inicio`}>
      <img class="site-header__logo" src="/assets/branding/logo-verde.png" alt={marca.nombre} width="120" height="40" />
    </a>

    <input class="site-header__toggle visually-hidden" type="checkbox" id="nav-toggle" aria-label="Abrir menú" />

    <nav class="site-nav" aria-label="Navegación principal">
      {nav.map((link) => (
        <a
          class="site-nav__link"
          href={link.url}
          aria-current={isActive(link.url) ? 'page' : undefined}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="site-header__actions">
      <a class="btn btn--primary site-header__cta" href={waUrl} target="_blank" rel="noopener noreferrer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M.057 24l1.687-6.163a11.867 11.867 0 01-1.587-5.946C.16 5.335 5.495 0 12.05 0a11.821 11.821 0 018.413 3.488 11.824 11.824 0 013.48 8.414c-.003 6.557-5.338 11.892-11.893 11.892a11.9 11.9 0 01-5.688-1.448L.057 24zm6.597-3.807c1.676.995 3.276 1.591 5.316 1.592 5.448 0 9.886-4.434 9.889-9.885.002-5.462-4.415-9.89-9.881-9.892-5.452 0-9.887 4.434-9.889 9.884a9.86 9.86 0 001.599 5.317l-.999 3.648 3.866-1.012zm11.387-5.464c-.074-.124-.272-.198-.57-.347-.297-.149-1.758-.868-2.031-.967-.272-.099-.47-.149-.669.149-.198.297-.768.967-.941 1.165-.173.198-.347.223-.644.074-.297-.149-1.255-.462-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.297-.347.446-.521.151-.172.2-.296.3-.495.099-.198.05-.372-.025-.521-.075-.148-.669-1.611-.916-2.206-.242-.579-.487-.501-.669-.51l-.57-.01c-.198 0-.52.074-.792.372s-1.04 1.016-1.04 2.479 1.065 2.876 1.213 3.074c.149.198 2.095 3.2 5.076 4.487.709.306 1.263.489 1.694.626.712.226 1.36.194 1.872.118.571-.085 1.758-.719 2.006-1.413.248-.695.248-1.29.173-1.414z"/>
        </svg>
        <span>Hablemos</span>
      </a>

      <label class="site-header__burger" for="nav-toggle">
        <span class="visually-hidden">Abrir o cerrar menú</span>
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" aria-hidden="true">
          <path d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </label>
    </div>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    inset-block-start: 0;
    z-index: 50;
    background-color: color-mix(in srgb, var(--color-surface) 92%, transparent);
    backdrop-filter: blur(10px);
    border-block-end: 1px solid var(--color-border);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    block-size: 4.25rem;
    position: relative;
  }
  .site-header__logo {
    block-size: 2.5rem;
    inline-size: auto;
  }
  .site-nav {
    display: none;
    align-items: center;
    gap: 1.75rem;
  }
  .site-nav__link {
    font-family: var(--font-heading);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--color-ink-soft);
    transition: color var(--duration-base) var(--ease-out);
  }
  .site-nav__link:hover { color: var(--color-brand-strong); }
  .site-nav__link[aria-current="page"] { color: var(--color-ink); font-weight: 600; }

  .site-header__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .site-header__cta { display: none; }
  .site-header__burger {
    display: inline-flex;
    cursor: pointer;
    color: var(--color-ink);
  }

  /* Menú móvil: panel desplegable controlado por el checkbox */
  .site-header__toggle:checked ~ .site-nav {
    display: flex;
    position: absolute;
    inset-block-start: 100%;
    inset-inline: calc(-1 * var(--layout-gutter));
    flex-direction: column;
    align-items: stretch;
    gap: 0;
    padding-block: 0.5rem;
    background-color: var(--color-surface);
    border-block-end: 1px solid var(--color-border);
    box-shadow: var(--shadow-card);
  }
  .site-header__toggle:checked ~ .site-nav .site-nav__link {
    padding: 0.85rem var(--layout-gutter);
    border-block-start: 1px solid var(--color-surface-sunken);
  }

  @media (min-width: 60rem) {
    .site-nav { display: flex; }
    .site-header__cta { display: inline-flex; }
    .site-header__burger { display: none; }
  }
</style>
