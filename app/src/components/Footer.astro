---
import { getConfig } from '../lib/content';

const config = await getConfig();
const { marca, contacto, footer, redes, nav, whatsapp } = config;
const waUrl = `https://wa.me/${whatsapp.numero}?text=${encodeURIComponent(whatsapp.mensaje_default)}`;
const year = new Date().getFullYear();

const redLabel = (red: string) => red.charAt(0).toUpperCase() + red.slice(1);
---

<footer class="site-footer">
  <div class="container site-footer__top">
    <div class="site-footer__brand">
      <img class="site-footer__logo" src="/assets/branding/logo-blanco.png" alt={marca.nombre} width="140" height="48" loading="lazy" />
      <p class="site-footer__desc">{footer.descripcion}</p>
      {redes.length > 0 && (
        <ul class="site-footer__social" aria-label="Redes sociales">
          {redes.map((r) => (
            <li>
              <a class="site-footer__social-link" href={r.url} target="_blank" rel="noopener noreferrer">
                <span class="visually-hidden">{redLabel(r.red)}</span>
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2.16c3.2 0 3.58.01 4.85.07 1.17.05 1.8.25 2.23.41.56.22.96.48 1.38.9.42.42.68.82.9 1.38.16.42.36 1.06.41 2.23.06 1.27.07 1.65.07 4.85s-.01 3.58-.07 4.85c-.05 1.17-.25 1.8-.41 2.23-.22.56-.48.96-.9 1.38-.42.42-.82.68-1.38.9-.42.16-1.06.36-2.23.41-1.27.06-1.65.07-4.85.07s-3.58-.01-4.85-.07c-1.17-.05-1.8-.25-2.23-.41a3.7 3.7 0 01-1.38-.9 3.7 3.7 0 01-.9-1.38c-.16-.42-.36-1.06-.41-2.23-.06-1.27-.07-1.65-.07-4.85s.01-3.58.07-4.85c.05-1.17.25-1.8.41-2.23.22-.56.48-.96.9-1.38.42-.42.82-.68 1.38-.9.42-.16 1.06-.36 2.23-.41C8.42 2.17 8.8 2.16 12 2.16zm0 1.62c-3.15 0-3.52.01-4.76.07-1.15.05-1.77.24-2.19.4-.55.22-.94.47-1.35.88-.41.41-.66.8-.88 1.35-.16.42-.35 1.04-.4 2.19-.06 1.24-.07 1.61-.07 4.76s.01 3.52.07 4.76c.05 1.15.24 1.77.4 2.19.22.55.47.94.88 1.35.41.41.8.66 1.35.88.42.16 1.04.35 2.19.4 1.24.06 1.61.07 4.76.07s3.52-.01 4.76-.07c1.15-.05 1.77-.24 2.19-.4.55-.22.94-.47 1.35-.88.41-.41.66-.8.88-1.35.16-.42.35-1.04.4-2.19.06-1.24.07-1.61.07-4.76s-.01-3.52-.07-4.76c-.05-1.15-.24-1.77-.4-2.19a3.63 3.63 0 00-.88-1.35 3.63 3.63 0 00-1.35-.88c-.42-.16-1.04-.35-2.19-.4-1.24-.06-1.61-.07-4.76-.07zm0 2.76a5.3 5.3 0 110 10.6 5.3 5.3 0 010-10.6zm0 1.62a3.68 3.68 0 100 7.36 3.68 3.68 0 000-7.36zm5.5-2.91a1.24 1.24 0 110 2.48 1.24 1.24 0 010-2.48z"/>
                </svg>
              </a>
            </li>
          ))}
        </ul>
      )}
    </div>

    <nav class="site-footer__col" aria-label="Mapa del sitio">
      <h2 class="site-footer__heading">Navegación</h2>
      <ul class="site-footer__list">
        {nav.map((link) => (
          <li><a class="site-footer__link" href={link.url}>{link.label}</a></li>
        ))}
      </ul>
    </nav>

    <div class="site-footer__col">
      <h2 class="site-footer__heading">Contacto</h2>
      <ul class="site-footer__list">
        <li><a class="site-footer__link" href={`mailto:${contacto.email}`}>{contacto.email}</a></li>
        <li><a class="site-footer__link" href={`tel:${contacto.telefono_e164}`}>{contacto.telefono_display}</a></li>
        <li><a class="site-footer__link" href={waUrl} target="_blank" rel="noopener noreferrer">WhatsApp</a></li>
        <li class="site-footer__muted">{contacto.direccion}</li>
      </ul>
    </div>
  </div>

  <div class="site-footer__bottom">
    <div class="container site-footer__bottom-inner">
      <p class="site-footer__copy">© {year} {marca.nombre}. Todos los derechos reservados.</p>
      <ul class="site-footer__legal">
        {footer.bottom_links.map((link) => (
          <li><a class="site-footer__link" href={link.url}>{link.label}</a></li>
        ))}
      </ul>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    background-color: var(--color-ink);
    color: color-mix(in srgb, var(--color-on-brand) 78%, transparent);
  }
  .site-footer__top {
    display: grid;
    gap: clamp(2rem, 5vw, 3.5rem);
    padding-block: clamp(3rem, 6vw, 4.5rem);
    grid-template-columns: 1fr;
  }
  .site-footer__logo { block-size: 3rem; inline-size: auto; }
  .site-footer__desc {
    margin-block: 1.25rem 1.5rem;
    max-width: 26rem;
    font-size: 0.95rem;
    line-height: 1.7;
  }
  .site-footer__social { display: flex; gap: 0.75rem; list-style: none; margin: 0; padding: 0; }
  .site-footer__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: 2.5rem;
    block-size: 2.5rem;
    border-radius: var(--radius-pill);
    background-color: color-mix(in srgb, var(--color-on-brand) 10%, transparent);
    color: var(--color-on-brand);
    transition: background-color var(--duration-base) var(--ease-out);
  }
  .site-footer__social-link:hover { background-color: var(--color-brand); }

  .site-footer__heading {
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-on-brand);
    margin-block-end: 1.25rem;
  }
  .site-footer__list { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.75rem; }
  .site-footer__link {
    font-size: 0.95rem;
    color: inherit;
    transition: color var(--duration-base) var(--ease-out);
  }
  .site-footer__link:hover { color: var(--color-brand); }
  .site-footer__muted { font-size: 0.9rem; opacity: 0.7; }

  .site-footer__bottom {
    border-block-start: 1px solid color-mix(in srgb, var(--color-on-brand) 12%, transparent);
  }
  .site-footer__bottom-inner {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding-block: 1.5rem;
  }
  .site-footer__copy { margin: 0; font-size: 0.85rem; opacity: 0.7; }
  .site-footer__legal { display: flex; gap: 1.5rem; list-style: none; margin: 0; padding: 0; font-size: 0.85rem; }

  @media (min-width: 48rem) {
    .site-footer__top { grid-template-columns: 2fr 1fr 1fr; }
  }
</style>
