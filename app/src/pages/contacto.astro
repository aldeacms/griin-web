---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ContactForm from '../components/ContactForm.astro';
import { getContacto, getConfig } from '../lib/content';

const config = await getConfig();
const contacto = await getContacto();
const { whatsapp, contacto: info, redes } = config;
const waUrl = `https://wa.me/${whatsapp.numero}?text=${encodeURIComponent(whatsapp.mensaje_default)}`;

const channels = [
  { label: 'Correo', value: info.email, href: `mailto:${info.email}`, icon: 'mail' },
  { label: 'Teléfono', value: info.telefono_display, href: `tel:${info.telefono_e164}`, icon: 'phone' },
  { label: 'WhatsApp', value: info.telefono_display, href: waUrl, icon: 'wa', external: true },
];

const icons: Record<string, string> = {
  mail: '<rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>',
  phone: '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92Z"/>',
  wa: '<path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5Z"/>',
};

const title = `Contacto — ${config.marca.nombre}`;
---

<BaseLayout title={title} description={contacto.subtitulo}>
  <PageHero eyebrow={contacto.eyebrow} title={contacto.titulo} lead={contacto.subtitulo} />

  <section class="section">
    <div class="container contacto__grid">
      <div class="contacto__form-card">
        <h2 class="contacto__form-title">Envíanos un mensaje</h2>
        <ContactForm />
      </div>

      <aside class="contacto__info">
        <h2 class="contacto__info-title">Canales directos</h2>
        <ul class="contacto__channels" role="list">
          {channels.map((ch) => (
            <li>
              <a class="contacto__channel" href={ch.href} target={ch.external ? '_blank' : undefined} rel={ch.external ? 'noopener noreferrer' : undefined}>
                <span class="contacto__channel-icon" aria-hidden="true">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={icons[ch.icon]} />
                </span>
                <span class="contacto__channel-text">
                  <span class="contacto__channel-label">{ch.label}</span>
                  <span class="contacto__channel-value">{ch.value}</span>
                </span>
              </a>
            </li>
          ))}
        </ul>

        <p class="contacto__address">
          <strong>Cobertura</strong><br />
          {info.direccion}
        </p>

        {redes.length > 0 && (
          <p class="contacto__social">
            {redes.map((r) => (
              <a class="contacto__social-link" href={r.url} target="_blank" rel="noopener noreferrer">
                {r.red.charAt(0).toUpperCase() + r.red.slice(1)}
              </a>
            ))}
          </p>
        )}
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .contacto__grid {
    display: grid;
    gap: clamp(2rem, 4vw, 3rem);
    grid-template-columns: 1fr;
    align-items: start;
  }
  .contacto__form-card {
    padding: clamp(1.75rem, 4vw, 2.5rem);
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-card);
  }
  .contacto__form-title { font-size: var(--text-subtitle); margin: 0 0 1.5rem; }

  .contacto__info { display: flex; flex-direction: column; gap: 1.25rem; }
  .contacto__info-title { font-size: 1.2rem; margin: 0; }
  .contacto__channels { display: flex; flex-direction: column; gap: 0.75rem; list-style: none; margin: 0; padding: 0; }
  .contacto__channel {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background-color: var(--color-surface);
    transition: border-color var(--duration-base) var(--ease-out), background-color var(--duration-base) var(--ease-out);
  }
  .contacto__channel:hover { border-color: var(--color-brand); background-color: var(--color-brand-soft); }
  .contacto__channel-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    inline-size: 2.5rem;
    block-size: 2.5rem;
    flex: 0 0 auto;
    border-radius: var(--radius-pill);
    background-color: var(--color-brand-soft);
    color: var(--color-brand-strong);
  }
  .contacto__channel-text { display: flex; flex-direction: column; }
  .contacto__channel-label { font-size: 0.8rem; color: var(--color-ink-muted); }
  .contacto__channel-value { font-family: var(--font-heading); font-weight: 600; color: var(--color-ink); }

  .contacto__address { margin: 0; color: var(--color-ink-soft); line-height: 1.6; }
  .contacto__address strong { color: var(--color-ink); }
  .contacto__social { margin: 0; display: flex; gap: 1rem; }
  .contacto__social-link { color: var(--color-brand-strong); font-weight: 600; }

  @media (min-width: 56rem) {
    .contacto__grid { grid-template-columns: 1.5fr 1fr; }
  }
</style>
